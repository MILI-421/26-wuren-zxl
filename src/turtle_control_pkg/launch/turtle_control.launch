<launch>
    <!-- 启动小海龟仿真节点 -->
    <node pkg="turtlesim" type="turtlesim_node" name="turtlesim" />

    <!-- 启动 Python 消息发布节点 -->
    <node pkg="turtle_control_pkg" type="turtle_speed_pub.py" name="turtle_speed_pub" output="screen" />

    <!-- 加载 YAML 参数到参数服务器 -->
    <rosparam file="$(find turtle_control_pkg)/config/turtle_params.yaml" command="load" />

    <!-- 启动 C++ 控制节点 -->
    <node pkg="turtle_control_pkg" type="turtle_control_node" name="turtle_control_node" output="screen" />
</launch>

